# Swagger Agent — LLM Configuration
# Copy this file to .env and modify as needed.

# ── Global defaults (used by all agents unless overridden) ──
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=default
LLM_API_KEY=not-needed
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=16384
INSTRUCTOR_MAX_RETRIES=3

# ── Per-agent model overrides (leave empty to use global default) ──
# LLM_MODEL_SCOUT=
# LLM_MODEL_ROUTE_EXTRACTOR=
# LLM_MODEL_SCHEMA_EXTRACTOR=
# LLM_MODEL_ORCHESTRATOR=

# ── Per-agent base URL overrides (leave empty to use global default) ──
# LLM_BASE_URL_SCOUT=
# LLM_BASE_URL_ROUTE_EXTRACTOR=
# LLM_BASE_URL_SCHEMA_EXTRACTOR=
# LLM_BASE_URL_ORCHESTRATOR=

# ── Concurrency (1 = sequential, increase based on LLM backend capacity) ──
MAX_WORKERS_ROUTE=1
MAX_WORKERS_SCHEMA=1

# ── Reasoning effort (thinking models) ──
# Works with: Google Gemini 2.5+, OpenAI o-series
# Values: none, low, medium, high (empty = model default)
# LLM_REASONING_EFFORT=low

# ── Instructor mode ──
# Mode: tools (default), json, json_schema, md_json, openrouter_structured_outputs
# Use "json_schema" for local models (llamacpp/vllm grammar-level enforcement)
# Use "json" or "openrouter_structured_outputs" for OpenRouter
# Use "tools" or "json_schema" for Google Gemini
INSTRUCTOR_MODE=tools


# ═══════════════════════════════════════════════════════════════════
# Provider presets — uncomment one block to switch providers
# ═══════════════════════════════════════════════════════════════════

# ── Local (llamacpp / vllm / ollama) ──
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=your-model-name
# LLM_API_KEY=not-needed
# INSTRUCTOR_MODE=json_schema

# ── Google Gemini (OpenAI-compatible endpoint) ──
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-3-flash-preview
# LLM_API_KEY=your-google-api-key
# INSTRUCTOR_MODE=json_schema
# LLM_REASONING_EFFORT=low
#
# Available models (latest first):
#   gemini-3.1-pro-preview        — best reasoning (Feb 2026)
#   gemini-3-flash-preview        — best speed/cost (current gen)
#   gemini-3.1-flash-lite-preview — cheapest (Mar 2026)
#   gemini-2.5-pro                — stable, deprecated June 2026
#   gemini-2.5-flash              — stable, deprecated June 2026

# ── DeepSeek (OpenAI-compatible) ──
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=your-deepseek-api-key
# LLM_MAX_TOKENS=8192

# ── OpenRouter ──
# LLM_BASE_URL=https://openrouter.ai/api/v1/
# LLM_MODEL=google/gemini-3.1-pro-preview
# LLM_API_KEY=your-openrouter-api-key
# LLM_MAX_TOKENS=4096
# INSTRUCTOR_MODE=openrouter_structured_outputs
