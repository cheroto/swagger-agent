{
  "endpoints": [
    {"method": "GET", "path": "/", "has_auth": false},
    {"method": "GET", "path": "/version", "has_auth": false},
    {"method": "POST", "path": "/api/login", "has_auth": false},
    {"method": "POST", "path": "/api/logout", "has_auth": false},
    {"method": "GET", "path": "/api/user", "has_auth": true},
    {"method": "POST", "path": "/api/sensor", "has_auth": true},
    {"method": "GET", "path": "/api/sensor/{sensor_id}", "has_auth": true},
    {"method": "DELETE", "path": "/api/sensor/{sensor_id}", "has_auth": true},
    {"method": "POST", "path": "/api/sensor/{sensor_id}/readings", "has_auth": true},
    {"method": "GET", "path": "/api/sensor/{sensor_id}/readings", "has_auth": true},
    {"method": "POST", "path": "/sensor/upload", "has_auth": true}
  ],
  "schemas": [
    {"name": "User", "properties": ["username", "name", "sensors"]},
    {"name": "Sensor", "properties": ["id", "name", "description", "api_key", "step"]},
    {"name": "Reading", "properties": ["sensor_id", "occurred", "readings"]},
    {"name": "ApiKey", "properties": ["id", "uuid"]},
    {"name": "ErrorDoc", "properties": ["error"]},
    {"name": "LoginDoc", "properties": ["username", "password"]},
    {"name": "SensorCreateDoc", "properties": ["name", "description", "step"]},
    {"name": "ReadingsCreateDoc", "properties": ["occurred", "readings"]},
    {"name": "SensorUploadRec", "properties": ["time", "value"]}
  ],
  "security_schemes": [
    {"name": "CookieAuth", "type": "apiKey"},
    {"name": "BearerAuth", "type": "http"}
  ]
}
